{
  "name": "kickable",
  "version": "1.0.0",
  "description": "Kickable is a service meant to answer the question \"Can I Kick It?\"",
  "main": "dist/index.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "ava",
    "test:coverage": "c8 --reporter=lcov --reporter=text ava"
  },
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "koa": "^3.2.1",
    "koa-route": "^4.0.1"
  },
  "devDependencies": {
    "@types/koa": "^3.0.3",
    "@types/koa-route": "^3.2.9",
    "@types/node": "^25.9.2",
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "eslint": "^10.4.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "ava": {
    "files": [
      "dist/test/**/*.js"
    ]
  }
}
